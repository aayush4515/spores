{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "components/**/*",
    "hooks/**/*",
    "lib/**/*",
    "styles/**/*",
    "app/layout.tsx",
    "app/page.tsx",
    "supabase/functions/**/*"
  ]
}
